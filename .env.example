# 匠人程云端后端配置样例
# 不要把真实 .env 提交到 GitHub。

JRC_CLOUD_PROVIDER=aliyun
JRC_SITE_ID=jrcedu-main

# 阿里云 RDS PostgreSQL
JRC_DB_HOST=
JRC_DB_PORT=5432
JRC_DB_NAME=jrcedu
JRC_DB_USER=jrcedu_app
JRC_DB_PASSWORD=
JRC_DB_SSL=true

# 后端 API
JRC_API_BASE_URL=
JRC_API_TOKEN=

# 备份与附件
JRC_OSS_BUCKET=
JRC_OSS_REGION=cn-hangzhou
